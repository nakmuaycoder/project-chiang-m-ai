# Project Chiang M-AI Environment Configuration
# Copy this file to .env and fill in your credentials

# Required - Intervals.icu API
INTERVALS_ATHLETE_ID=i12345
INTERVALS_API_KEY=your_intervals_key_here

# Required - Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json

# Optional - Training Configuration
PERIODIZATION=3:1  # Training block pattern: "3:1" (28 days) or "2:1" (21 days)
DB_PATH=data/workout_sync_history.json

# Optional - Wellness Adaptation
WELLNESS_HISTORY_DAYS=10

# LLM Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Quick Setup:
# Run: uv run setup_keys.py --intervals_id="i12345" --intervals_key="KEY" --calendar_creds="path/to/creds.json"
